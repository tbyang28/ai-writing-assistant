# 必填：JWT 加密密钥，请替换为强密码
SECRET_KEY=change-this-to-a-strong-secret-key

# 数据库（默认 SQLite，数据持久化在 volume 中）
DATABASE_URL=sqlite+aiosqlite:////app/data/writing_platform.db

# JWT 配置
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SiliconFlow API（AI 功能必需）
SILICONFLOW_API_KEY=your-api-key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V4-Flash

# 同域名反代部署时保持为空，前端会用相对路径 /api/ 访问后端
VITE_API_URL=
